# DentalOperix 57.8-C Controlled Production Cutover Template
# Copy locally to .env.cutover.prod. Do not commit real secrets.

PORT=3000
NODE_ENV=production

# Google rollback/reference configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/spreadsheets
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_NAME=Leads
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Panama
GMAIL_SENDER=your-email@example.com

# Supabase/PostgreSQL production persistence
DATABASE_URL=postgresql://user:password@host:6543/postgres
POSTGRES_URL=
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Runtime activation - only true during approved controlled production cutover window
LEADS_PERSISTENCE_MODE=relational-db
RELATIONAL_CUTOVER_APPROVED=true
RELATIONAL_RUNTIME_ACTIVATION_APPROVED=true
RELATIONAL_PRODUCTION_CUTOVER_READINESS_APPROVED=true
RELATIONAL_POST_CUTOVER_VALIDATION_APPROVED=true

# Admin/server-only
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
INTERNAL_API_KEY=change-me
