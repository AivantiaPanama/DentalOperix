# DentalOperix 57.7 Relational Persistence Test Environment Template
# Copy to .env.relational.local for local validation only.
# Do not commit real secrets.

PORT=3000
NODE_ENV=development

# 57.x governance default: keep Google Sheet active unless an approved test explicitly overrides it.
# Allowed values: google-sheet, relational-db
LEADS_PERSISTENCE_MODE=google-sheet

# Current physical persistence. Required for rollback validation and current operations.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/spreadsheets
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_NAME=Leads
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Panama
GMAIL_SENDER=your-email@example.com

# Future physical persistence. Fill only after the approved database exists.
# Use the connection string format provided by the selected database provider.
DATABASE_URL=

# Optional provider-specific aliases. Keep empty unless the selected provider requires them.
POSTGRES_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Governance controls for validation scripts.
# This must remain false unless an explicit cutover execution window is approved.
RELATIONAL_CUTOVER_APPROVED=false
# Optional: set to true only in an isolated dry-run environment.
RELATIONAL_CONNECTIVITY_TEST_ENABLED=false

# Admin access (server-only)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
INTERNAL_API_KEY=dev-local-secret-change-me

# 57.7-C schema-only deployment controls.
# Keep false unless explicitly preparing the Supabase schema.
RELATIONAL_SCHEMA_DEPLOYMENT_APPROVED=false
RELATIONAL_SCHEMA_DEPLOYMENT_ENABLED=false
