PORT=3000
NODE_ENV=development

# Public Vite env vars must be prefixed with VITE_
# Example public API base URL for frontend use:
VITE_API_BASE_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/calendar https://www.googleapis.com/auth/spreadsheets
# GOOGLE_REFRESH_TOKEN is optional during initial OAuth setup. It will be generated after completing the auth flow.
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_NAME=Leads
GOOGLE_FOLLOWUPS_SHEET_NAME=PatientFollowUps
GOOGLE_AUTOMATION_SHEET_NAME=AutomationRuns
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Santiago
GMAIL_SENDER=your-email@example.com
CLINIC_NOTIFICATION_EMAIL=clinic@example.com

# Required in production for protected internal APIs. Use a long random secret.
INTERNAL_API_KEY=dev-local-secret-change-me

# Admin access (server-only)
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
